    <!-- http://purl.obolibrary.org/obo/CO_321_0000042 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CO_321_0000042">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CO_321_0000003"/>
        <metadata:treeView rdf:resource="http://purl.obolibrary.org/obo/CO_321_0000003"/>
        <obo:IAO_0000115 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">One of the key quality parameters in the determination of Durum quality referring to translucent or glass-like appearance when seeds are transversely sectioned and observed whether not vitreous/partly vitreous/vitreous. It is associated with high protein and hard grain.</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace rdf:datatype="http://www.w3.org/2001/XMLSchema#string">wheat_trait</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">grain vitreousness</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CO_321:0000042</oboInOwl:id>
        <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Partly vitreous endosperm is related to the efficiency in N fertilization to allow accumulation of acceptable levels of protein content in the grain. Deficient N fertilization results in low grain protein content and starchy patches in the endosperm.</rdfs:comment>
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">seed vitreousness</rdfs:label>
        <skos:notation rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CO:321:0000042</skos:notation>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CO_321_0000042"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget rdf:datatype="http://www.w3.org/2001/XMLSchema#string">One of the key quality parameters in the determination of Durum quality referring to translucent or glass-like appearance when seeds are transversely sectioned and observed whether not vitreous/partly vitreous/vitreous. It is associated with high protein and hard grain.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CIMMYT:jp�</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CO:rs �AGPG:IBPGR/85/210</oboInOwl:hasDbXref>
    </owl:Axiom>
    


