        <oboInOwl:hasRelatedSynonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">tan spot</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">yellow leaf spot</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CO_321:0000135</oboInOwl:id>
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">pyrenophora yellow leaf blotch</rdfs:label>
        <skos:notation rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CO:321:0000135</skos:notation>
    </owl:Class>
