    <!-- http://purl.obolibrary.org/obo/CO_321_0000102 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CO_321_0000102">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CO_321_0000122"/>
        <metadata:treeView rdf:resource="http://purl.obolibrary.org/obo/CO_321_0000122"/>
        <obo:IAO_0000115 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The trait is scored for the plant response to the agents necrotrophic fungus Tapesia yallundae (Pseudocercosporella herpotrichoide W-type) and Tapesia acuformis (Pseudocercosporella herpotrichoides R-type)causing eye spot disease. Symptoms: The eye shape elliptical lesions forms on lower base of stem and lower leaf sheath. The eyespots are straw yellow in color from the middle and are surrounded by the greenish brown to dark brown rings.</obo:IAO_0000115>
        <oboInOwl:hasDbXref rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IWIS_TRAITID:1116</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace rdf:datatype="http://www.w3.org/2001/XMLSchema#string">wheat_trait</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PHERP</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">strawbreaker</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CO_321:0000102</oboInOwl:id>
        <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">eyespot</rdfs:label>
        <skos:notation rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CO:321:0000102</skos:notation>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CO_321_0000102"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The trait is scored for the plant response to the agents necrotrophic fungus Tapesia yallundae (Pseudocercosporella herpotrichoide W-type) and Tapesia acuformis (Pseudocercosporella herpotrichoides R-type)causing eye spot disease. Symptoms: The eye shape elliptical lesions forms on lower base of stem and lower leaf sheath. The eyespots are straw yellow in color from the middle and are surrounded by the greenish brown to dark brown rings.</owl:annotatedTarget>
        <oboInOwl:hasDbXref rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CO:rs</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref rdf:datatype="http://www.w3.org/2001/XMLSchema#string">http://en.wikipedia.org/wiki/Eyespot_(wheat)</oboInOwl:hasDbXref>
